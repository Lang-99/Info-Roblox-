<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ROBLOX ELITE FINDER</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }
        
        :root {
            --bg-primary: #0a0e27;
            --bg-secondary: #111827;
            --bg-card: #1a1f3a;
            --accent-primary: #6366f1;
            --accent-secondary: #ec4899;
            --accent-success: #10b981;
            --accent-warning: #f59e0b;
            --accent-danger: #ef4444;
            --text-primary: #f9fafb;
            --text-secondary: #9ca3af;
            --border-color: rgba(99, 102, 241, 0.2);
        }
        
        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            overflow-x: hidden;
            min-height: 100vh;
            position: relative;
        }
        
        /* Animated Background */
        .bg-animated {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            overflow: hidden;
        }
        
        .bg-gradient {
            position: absolute;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 50%, #0a0e27 100%);
        }
        
        .bg-grid {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(99, 102, 241, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(99, 102, 241, 0.03) 1px, transparent 1px);
            background-size: 30px 30px;
            animation: gridMove 20s linear infinite;
        }
        
        @keyframes gridMove {
            0% { transform: translate(0, 0); }
            100% { transform: translate(30px, 30px); }
        }
        
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.4;
            animation: float 20s ease-in-out infinite;
        }
        
        .orb-1 {
            width: 300px;
            height: 300px;
            background: var(--accent-primary);
            top: 10%;
            left: 10%;
            animation-delay: 0s;
        }
        
        .orb-2 {
            width: 400px;
            height: 400px;
            background: var(--accent-secondary);
            bottom: 10%;
            right: 10%;
            animation-delay: 5s;
        }
        
        @keyframes float {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(50px, -50px) scale(1.1); }
            66% { transform: translate(-50px, 50px) scale(0.9); }
        }
        
        /* Container */
        .container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 16px;
        }
        
        /* Status Bar */
        .status-bar {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        
        .status-card {
            flex: 1;
            min-width: 140px;
            background: rgba(26, 31, 58, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .status-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }
        
        .status-icon.online {
            background: linear-gradient(135deg, var(--accent-success), #059669);
        }
        
        .status-icon.users {
            background: linear-gradient(135deg, var(--accent-primary), #4f46e5);
        }
        
        .status-info h3 {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--text-secondary);
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }
        
        .status-info p {
            font-size: 18px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
        }
        
        /* Card */
        .card {
            background: rgba(26, 31, 58, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 20px;
        }
        
        /* Login */
        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .login-card {
            width: 100%;
            max-width: 420px;
        }
        
        .logo {
            text-align: center;
            margin-bottom: 32px;
        }
        
        .logo-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 16px;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            animation: pulse 2s ease-in-out infinite;
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.7); }
            50% { transform: scale(1.05); box-shadow: 0 0 0 20px rgba(99, 102, 241, 0); }
        }
        
        .logo h1 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .logo p {
            color: var(--text-secondary);
            font-size: 14px;
        }
        
        /* Form */
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--text-secondary);
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }
        
        .form-group input {
            width: 100%;
            padding: 16px;
            background: rgba(17, 24, 39, 0.6);
            border: 2px solid rgba(99, 102, 241, 0.2);
            border-radius: 12px;
            color: var(--text-primary);
            font-size: 16px;
            font-family: 'Space Grotesk', sans-serif;
            transition: all 0.3s;
        }
        
        .form-group input:focus {
            outline: none;
            border-color: var(--accent-primary);
            background: rgba(17, 24, 39, 0.8);
        }
        
        .btn {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 700;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Space Grotesk', sans-serif;
            letter-spacing: 0.5px;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            color: white;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
        }
        
        .btn-primary:active {
            transform: translateY(0);
        }
        
        .btn-danger {
            background: linear-gradient(135deg, var(--accent-danger), #dc2626);
            color: white;
        }
        
        .error-message {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid var(--accent-danger);
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 16px;
            color: var(--accent-danger);
            font-size: 14px;
            font-weight: 600;
            text-align: center;
        }
        
        .success-message {
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid var(--accent-success);
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 16px;
            color: var(--accent-success);
            font-size: 14px;
            font-weight: 600;
            text-align: center;
        }
        
        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 12px;
        }
        
        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .user-avatar {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 700;
        }
        
        .user-details h3 {
            font-size: 12px;
            text-transform: uppercase;
            color: var(--text-secondary);
            font-weight: 600;
            letter-spacing: 0.5px;
        }
        
        .user-details p {
            font-size: 18px;
            font-weight: 700;
        }
        
        /* Search */
        .search-form {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
        }
        
        .search-input {
            flex: 1;
        }
        
        .btn-search {
            padding: 16px 24px;
            white-space: nowrap;
        }
        
        /* Profile Card */
        .profile-card {
            text-align: center;
        }
        
        .profile-avatar-container {
            position: relative;
            display: inline-block;
            margin-bottom: 20px;
        }
        
        .profile-avatar {
            width: 120px;
            height: 120px;
            border-radius: 24px;
            border: 4px solid var(--border-color);
            object-fit: cover;
        }
        
        .profile-status {
            position: absolute;
            bottom: -8px;
            right: -8px;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            border: 4px solid var(--bg-card);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }
        
        .profile-status.online {
            background: linear-gradient(135deg, var(--accent-success), #059669);
        }
        
        .profile-status.offline {
            background: linear-gradient(135deg, #6b7280, #4b5563);
        }
        
        .profile-name {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 8px;
        }
        
        .profile-username {
            color: var(--text-secondary);
            font-size: 16px;
            margin-bottom: 12px;
        }
        
        .profile-status-text {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 4px;
        }
        
        .profile-status-text.online {
            color: var(--accent-success);
        }
        
        .profile-status-text.offline {
            color: var(--text-secondary);
        }
        
        .profile-last-seen {
            font-size: 12px;
            color: var(--text-secondary);
        }
        
        /* Badges */
        .badges {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: center;
            margin: 16px 0;
        }
        
        .badge {
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        
        .badge-admin {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: white;
        }
        
        .badge-youtuber {
            background: linear-gradient(135deg, #ef4444, #b91c1c);
            color: white;
        }
        
        .badge-developer {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: white;
        }
        
        .badge-influencer {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: white;
        }
        
        .badge-verified {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
        }
        
        .badge-player {
            background: linear-gradient(135deg, #8b5cf6, #7c3aed);
            color: white;
        }
        
        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }
        
        .stat-card {
            background: rgba(17, 24, 39, 0.6);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
        }
        
        .stat-icon {
            width: 48px;
            height: 48px;
            margin: 0 auto 12px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }
        
        .stat-label {
            font-size: 11px;
            text-transform: uppercase;
            color: var(--text-secondary);
            font-weight: 600;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        
        .stat-value {
            font-size: 28px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
        }
        
        /* Timeline */
        .timeline-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 12px;
        }
        
        .timeline-item {
            background: rgba(17, 24, 39, 0.6);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 16px;
            text-align: center;
        }
        
        .timeline-label {
            font-size: 11px;
            text-transform: uppercase;
            color: var(--text-secondary);
            font-weight: 600;
            margin-bottom: 8px;
        }
        
        .timeline-value {
            font-size: 16px;
            font-weight: 700;
        }
        
        /* Utilities */
        .hidden {
            display: none !important;
        }
        
        .text-center {
            text-align: center;
        }
        
        .mt-2 {
            margin-top: 8px;
        }
        
        .mb-2 {
            margin-bottom: 8px;
        }
        
        /* Loading */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* Responsive */
        @media (max-width: 640px) {
            .status-card {
                min-width: 100%;
            }
            
            .search-form {
                flex-direction: column;
            }
            
            .btn-search {
                width: 100%;
            }
            
            .stats-grid {
                grid-template-columns: 1fr;
            }
            
            .header {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .logo h1 {
                font-size: 28px;
            }
            
            .profile-name {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>
    <!-- Animated Background -->
    <div class="bg-animated">
        <div class="bg-gradient"></div>
        <div class="bg-grid"></div>
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
    </div>

    <!-- Login Page -->
    <div id="loginPage">
        <div class="login-container">
            <div class="login-card card">
                <div class="logo">
                    <div class="logo-icon">🎮</div>
                    <h1>ROBLOX ELITE</h1>
                    <p>Advanced Player Analytics</p>
                </div>

                <form id="loginForm">
                    <div id="loginError" class="error-message hidden"></div>
                    
                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" id="loginUsername" placeholder="Enter username" required>
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" id="loginPassword" placeholder="Enter password" required>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <span id="loginBtnText">LOGIN / REGISTER</span>
                    </button>

                    <p class="text-center mt-2" style="font-size: 12px; color: var(--text-secondary);">
                        Auto-register if account doesn't exist
                    </p>
                </form>
            </div>
        </div>
    </div>

    <!-- Dashboard -->
    <div id="dashboard" class="hidden">
        <div class="container">
            <!-- Status Bar -->
            <div class="status-bar">
                <div class="status-card">
                    <div class="status-icon online">✓</div>
                    <div class="status-info">
                        <h3>Server</h3>
                        <p style="color: var(--accent-success);">ONLINE</p>
                    </div>
                </div>
                <div class="status-card">
                    <div class="status-icon users">👥</div>
                    <div class="status-info">
                        <h3>Users</h3>
                        <p id="onlineCount" style="color: var(--accent-primary);">1,337</p>
                    </div>
                </div>
            </div>

            <!-- Header -->
            <div class="card">
                <div class="header">
                    <div class="user-info">
                        <div class="user-avatar" id="userAvatar">U</div>
                        <div class="user-details">
                            <h3>Operator</h3>
                            <p id="loggedUser">User</p>
                        </div>
                    </div>
                    <button class="btn btn-danger" id="logoutBtn" style="width: auto; padding: 12px 24px;">
                        LOGOUT
                    </button>
                </div>
            </div>

            <!-- Search -->
            <div class="card">
                <h2 style="font-size: 20px; margin-bottom: 16px; font-weight: 700;">🔍 Search Player</h2>
                
                <form id="searchForm">
                    <div id="searchError" class="error-message hidden"></div>
                    
                    <div class="search-form">
                        <div class="search-input">
                            <input type="text" id="searchUsername" placeholder="Enter Roblox username" required style="width: 100%; padding: 16px; background: rgba(17, 24, 39, 0.6); border: 2px solid var(--border-color); border-radius: 12px; color: white; font-size: 16px;">
                        </div>
                        <button type="submit" class="btn btn-primary btn-search" id="searchBtn">
                            <span id="searchBtnText">SEARCH</span>
                        </button>
                    </div>
                </form>
            </div>

            <!-- Results -->
            <div id="results" class="hidden">
                <!-- Profile -->
                <div class="card profile-card">
                    <div class="profile-avatar-container">
                        <img id="profileAvatar" class="profile-avatar" src="" alt="Avatar">
                        <div id="profileStatus" class="profile-status online">✓</div>
                    </div>
                    
                    <h2 class="profile-name" id="profileName">Username</h2>
                    <p class="profile-username">@<span id="profileUsername">username</span></p>
                    
                    <div class="badges" id="profileBadges"></div>
                    
                    <p class="profile-status-text" id="statusText">ONLINE</p>
                    <p class="profile-last-seen" id="lastSeen"></p>
                </div>

                <!-- Stats -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">🆔</div>
                        <p class="stat-label">User ID</p>
                        <p class="stat-value" id="statId">0</p>
                    </div>
                    
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">📅</div>
                        <p class="stat-label">Join Year</p>
                        <p class="stat-value" id="statYear">0</p>
                    </div>
                    
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #10b981, #059669);">📈</div>
                        <p class="stat-label">Years</p>
                        <p class="stat-value" id="statYears">0</p>
                    </div>
                    
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);">⏱️</div>
                        <p class="stat-label">Days</p>
                        <p class="stat-value" id="statDays">0</p>
                    </div>
                </div>

                <!-- Timeline -->
                <div class="card">
                    <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 16px;">📊 Timeline</h3>
                    <div class="timeline-grid">
                        <div class="timeline-item">
                            <p class="timeline-label">Join Date</p>
                            <p class="timeline-value" id="timelineDate">-</p>
                        </div>
                        <div class="timeline-item">
                            <p class="timeline-label">Months</p>
                            <p class="timeline-value" id="timelineMonths">-</p>
                        </div>
                        <div class="timeline-item">
                            <p class="timeline-label">Age</p>
                            <p class="timeline-value" id="timelineAge">-</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Famous Users Database
        const FAMOUS_USERS = {
            'Flamingo': { type: 'youtuber', verified: true },
            'KreekCraft': { type: 'youtuber', verified: true },
            'Builderman': { type: 'admin', verified: true },
            'Shedletsky': { type: 'admin', verified: true },
            'Roblox': { type: 'admin', verified: true },
            'AlvinBlox': { type: 'developer', verified: true },
            'Badcc': { type: 'developer', verified: true },
            'Asimo3089': { type: 'developer', verified: true },
            'Tofuu': { type: 'youtuber', verified: true },
            'DenisDaily': { type: 'youtuber', verified: true },
            'Poke': { type: 'youtuber', verified: true },
            'ItsFunneh': { type: 'youtuber', verified: true },
            'Sketch': { type: 'youtuber', verified: true },
            'Thinknoodles': { type: 'youtuber', verified: true },
            'Linkmon99': { type: 'influencer', verified: true }
        };

        // Elements
        const loginPage = document.getElementById('loginPage');
        const dashboard = document.getElementById('dashboard');
        const loginForm = document.getElementById('loginForm');
        const searchForm = document.getElementById('searchForm');
        const results = document.getElementById('results');

        // Login Handler
        loginForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            const username = document.getElementById('loginUsername').value.trim();
            const password = document.getElementById('loginPassword').value.trim();
            const errorDiv = document.getElementById('loginError');

            if (!username || !password) {
                errorDiv.textContent = 'Please fill all fields';
                errorDiv.classList.remove('hidden');
                return;
            }

            const users = JSON.parse(localStorage.getItem('users') || '[]');
            const user = users.find(u => u.username === username);

            if (user) {
                if (user.password === password) {
                    localStorage.setItem('currentUser', username);
                    showDashboard(username);
                } else {
                    errorDiv.textContent = 'Wrong password';
                    errorDiv.classList.remove('hidden');
                }
            } else {
                users.push({ username, password });
                localStorage.setItem('users', JSON.stringify(users));
                localStorage.setItem('currentUser', username);
                showDashboard(username);
            }
        });

        // Show Dashboard
        function showDashboard(username) {
            loginPage.classList.add('hidden');
            dashboard.classList.remove('hidden');
            document.getElementById('loggedUser').textContent = username;
            document.getElementById('userAvatar').textContent = username.charAt(0).toUpperCase();
        }

        // Logout
        document.getElementById('logoutBtn').addEventListener('click', () => {
            localStorage.removeItem('currentUser');
            loginPage.classList.remove('hidden');
            dashboard.classList.add('hidden');
            results.classList.add('hidden');
            loginForm.reset();
        });

        // Search Handler
        searchForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const username = document.getElementById('searchUsername').value.trim();
            const errorDiv = document.getElementById('searchError');
            const btnText = document.getElementById('searchBtnText');
            const btn = document.getElementById('searchBtn');

            if (!username) {
                errorDiv.textContent = 'Please enter a username';
                errorDiv.classList.remove('hidden');
                return;
            }

            errorDiv.classList.add('hidden');
            btn.disabled = true;
            btnText.innerHTML = '<div class="loading"></div>';

            try {
                // Search user
                const searchRes = await fetch(`https://users.roblox.com/v1/users/search?keyword=${username}&limit=1`);
                const searchData = await searchRes.json();

                if (!searchData.data || searchData.data.length === 0) {
                    throw new Error('User not found');
                }

                const userId = searchData.data[0].id;
                const displayName = searchData.data[0].displayName;

                // Get details
                const detailRes = await fetch(`https://users.roblox.com/v1/users/${userId}`);
                const detailData = await detailRes.json();

                // Get avatar
                const avatarRes = await fetch(`https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds=${userId}&size=150x150&format=Png`);
                const avatarData = await avatarRes.json();
                const avatarUrl = avatarData.data[0].imageUrl;

                // Get presence
                const presenceRes = await fetch(`https://presence.roblox.com/v1/presence/users`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userIds: [userId] })
                });
                const presenceData = await presenceRes.json();
                const isOnline = presenceData.userPresences[0].userPresenceType === 2;
                const lastOnline = presenceData.userPresences[0].lastOnline;

                // Calculate
                const joinDate = new Date(detailData.created);
                const now = new Date();
                const days = Math.floor((now - joinDate) / (1000 * 60 * 60 * 24));
                const years = Math.floor(days / 365);
                const months = Math.floor(days / 30);

                // Display
                displayResults({
                    id: userId,
                    username: detailData.name,
                    displayName: displayName,
                    avatar: avatarUrl,
                    isOnline: isOnline,
                    lastOnline: lastOnline,
                    joinDate: joinDate,
                    days: days,
                    years: years,
                    months: months
                });

            } catch (error) {
                errorDiv.textContent = error.message || 'Failed to fetch data';
                errorDiv.classList.remove('hidden');
            } finally {
                btn.disabled = false;
                btnText.textContent = 'SEARCH';
            }
        });

        // Display Results
        function displayResults(data) {
            results.classList.remove('hidden');

            // Avatar & Status
            document.getElementById('profileAvatar').src = data.avatar;
            document.getElementById('profileName').textContent = data.displayName;
            document.getElementById('profileUsername').textContent = data.username;

            const statusDiv = document.getElementById('profileStatus');
            const statusText = document.getElementById('statusText');
            const lastSeen = document.getElementById('lastSeen');

            if (data.isOnline) {
                statusDiv.className = 'profile-status online';
                statusDiv.textContent = '✓';
                statusText.className = 'profile-status-text online';
                statusText.textContent = 'ONLINE NOW';
                lastSeen.textContent = '';
            } else {
                statusDiv.className = 'profile-status offline';
                statusDiv.textContent = '○';
                statusText.className = 'profile-status-text offline';
                statusText.textContent = 'OFFLINE';
                const date = new Date(data.lastOnline);
                lastSeen.textContent = `Last seen: ${date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`;
            }

            // Badges
            const badgesDiv = document.getElementById('profileBadges');
            badgesDiv.innerHTML = '';

            const userInfo = FAMOUS_USERS[data.username];
            if (userInfo) {
                if (userInfo.type === 'admin') {
                    badgesDiv.innerHTML += '<span class="badge badge-admin">⚡ ADMIN</span>';
                }
                if (userInfo.type === 'youtuber') {
                    badgesDiv.innerHTML += '<span class="badge badge-youtuber">📺 YOUTUBER</span>';
                }
                if (userInfo.type === 'developer') {
                    badgesDiv.innerHTML += '<span class="badge badge-developer">💻 DEVELOPER</span>';
                }
                if (userInfo.type === 'influencer') {
                    badgesDiv.innerHTML += '<span class="badge badge-influencer">🌟 INFLUENCER</span>';
                }
                if (userInfo.verified) {
                    badgesDiv.innerHTML += '<span class="badge badge-verified">✓ VERIFIED</span>';
                }
            }
            badgesDiv.innerHTML += '<span class="badge badge-player">⭐ PLAYER</span>';

            // Stats
            document.getElementById('statId').textContent = data.id.toLocaleString();
            document.getElementById('statYear').textContent = data.joinDate.getFullYear();
            document.getElementById('statYears').textContent = data.years;
            document.getElementById('statDays').textContent = data.days.toLocaleString();

            // Timeline
            document.getElementById('timelineDate').textContent = data.joinDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            document.getElementById('timelineMonths').textContent = `${data.months}`;
            document.getElementById('timelineAge').textContent = `${data.years}+ yrs`;

            // Scroll to results
            results.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // Online Count
        function updateOnlineCount() {
            const count = Math.floor(Math.random() * 500) + 1000;
            document.getElementById('onlineCount').textContent = count.toLocaleString();
        }

        // Init
        window.addEventListener('DOMContentLoaded', () => {
            const currentUser = localStorage.getItem('currentUser');
            if (currentUser) {
                showDashboard(currentUser);
            }
            
            updateOnlineCount();
            setInterval(updateOnlineCount, 10000);
        });
    </script>
</body>
</html>
